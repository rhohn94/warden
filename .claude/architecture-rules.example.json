{
  "schema-version": 1,
  "_comment": "Opt-in architecture + structure fitness rules for the grm-architecture-audit skill. Copy to .claude/architecture-rules.json and adapt to this project. Absent file => architecture-audit reports 'no rules declared' and exits clean. The 'structure' block encodes the standard project layout — full contract: docs/project-structure.md. Design: docs/grimoire/design/architecture-fitness-design.md, docs/grimoire/design/file-structure-standard-design.md",
  "structure": {
    "spec": "docs/project-structure.md",
    "required": ["src", "docs", "tests"],
    "aliases": {
      "vendor": "lib/third-party",
      "deps": "lib/third-party",
      "third_party": "lib/third-party",
      "test": "tests",
      "spec": "tests",
      "script": "scripts",
      "source": "src",
      "build": "dist",
      "out": "dist",
      "static": "assets",
      "resources": "assets"
    },
    "gitignored": ["dist", "build"]
  },
  "layers": {
    "presentation": ["src/ui/**", "src/views/**", "src/components/**"],
    "application": ["src/services/**", "src/app/**"],
    "domain": ["src/domain/**", "src/core/**"],
    "persistence": ["src/store/**", "src/db/**", "src/repositories/**"]
  },
  "allowed-edges": [
    ["presentation", "application"],
    ["application", "domain"],
    ["application", "persistence"],
    ["persistence", "domain"]
  ],
  "forbidden-imports": [
    { "id": "no-sql-in-view", "from": "presentation", "pattern": "sql|knex|prisma|sqlx|sequelize", "severity": "error" },
    { "id": "no-internal-reach", "pattern": "/internal/|/_private/", "severity": "warn" }
  ],
  "forbid-cycles": true
}
