{
  "schema-version": 1,
  "default-profile": "Medium",
  "bands": ["trivial", "small", "medium", "large", "review", "orchestrate"],
  "band-triggers": {
    "trivial": "<= 15K est. tokens; mechanical/read-only (lookups, text extraction, search)",
    "small": "15K-40K est. tokens; localized edits, single-file changes",
    "medium": "40K-80K est. tokens; multi-file implementation, test runs",
    "large": "> 80K est. tokens; cross-cutting implementation",
    "review": "any planning, code review, security review, architecture/design analysis (regardless of token estimate)",
    "orchestrate": "role-triggered, not token-triggered: release-orchestration agents the session dispatches (release-master loop iterations, PM lane integration masters). Escalates exceptions to a one-shot adjudicator resolved via the review band."
  },
  "ux-pins": {
    "design-language-adapt": { "model": "sonnet", "effort": "medium" },
    "ux-demo-build": { "model": "sonnet", "effort": "high" }
  },
  "profiles": {
    "Cheap-Sonnet": {
      "trivial": { "model": "haiku",  "effort": "low" },
      "small":   { "model": "sonnet", "effort": "low" },
      "medium":  { "model": "sonnet", "effort": "low" },
      "large":   { "model": "sonnet", "effort": "medium" },
      "review":  { "model": "sonnet", "effort": "medium" }
    },
    "Medium": {
      "trivial": { "model": "haiku",  "effort": "low" },
      "small":   { "model": "sonnet", "effort": "inherit" },
      "medium":  { "model": "sonnet", "effort": "inherit" },
      "large":   { "model": "opus",   "effort": "high" },
      "review":  { "model": "opus",   "effort": "high" },
      "orchestrate": { "model": "sonnet", "effort": "high" }
    },
    "High Effort": {
