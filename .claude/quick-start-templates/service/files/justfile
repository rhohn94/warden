# Quick-start task runner (just — https://github.com/casey/just).
#
# Dev-DB recipes use a Dockerized Postgres shared across git worktrees. See the
# "Multi-worktree shared-container behaviour" note below the db recipes. NOTE:
# the scaffolded service (a healthz-only starter) does NOT depend on the DB
# yet — `run`/`test` do not require `db-up`. db-up/db-down/compose.yaml ship
# ready for when you wire real persistence (recordkeeper et al.); add the
# `: db-up` dependency back to `run`/`test` at that point.

set shell := ["bash", "-uc"]

# ---------------------------------------------------------------------------
# Dev database (Dockerized Postgres)
# ---------------------------------------------------------------------------

# The compose service's container_name. Keep this in sync with compose.yaml.
db_name := "service-db"

# Idempotent, multi-worktree-safe DB bring-up (#81).
#
# Grimoire encourages one isolated git worktree per agent/task. Each worktree is
# its own Docker Compose PROJECT (name derived from its directory), but they all
# share the same hardcoded container_name. So a plain `docker compose up` from
# worktree B fails when worktree A's container is already up:
#
#   Conflict. The container name "/service-db" is already in use ...
#
# That container is already running and healthy on the published host port, which
# is exactly what every worktree needs (same host DATABASE_URL, localhost:5432).
# Recreating it under a different compose project would attach a different,
# project-prefixed EMPTY named volume and silently lose the seeded data.
#
# So this recipe is idempotent across worktrees: reuse a running container, start
# a stopped one, and only `docker compose up` when none exists. It detects the
# container with `docker ps` FILTERS (-f name=… -f health=healthy) rather than
# Go-template output (`--format '{{...}}'`) — the `{{ }}` collides with just's
# own interpolation and breaks the recipe.
db-up:
    #!/usr/bin/env bash
    set -euo pipefail
    name="{{db_name}}"               # the compose container_name
    filt="name=^/${name}$"           # exact-name filter (docker stores a leading /)

    wait_healthy() {
        for _ in $(seq 1 60); do
            [ -n "$(docker ps -q -f "$filt" -f health=healthy)" ] && return 0
            sleep 0.5
        done
        [ -n "$(docker ps -q -f "$filt")" ] && return 0   # no healthcheck → running is enough
        echo "db-up: timed out waiting for '$name' to become healthy." >&2
        return 1
    }

    if [ -n "$(docker ps -q -f "$filt")" ]; then
        echo "db-up: '$name' is already running — reusing it."
        wait_healthy
    elif [ -n "$(docker ps -aq -f "$filt")" ]; then
        echo "db-up: starting existing stopped container '$name'."
        docker start "$name" >/dev/null
        wait_healthy
    else
        docker compose up -d --wait db
    fi

# Stop the shared dev DB. NOTE: other worktrees may still be using this
# container — only stop it when no worktree needs it. Data persists in the
# named volume; this does not delete it.
db-down:
    docker compose stop db || true

# ---------------------------------------------------------------------------
# Multi-worktree shared-container behaviour (#81)
# ---------------------------------------------------------------------------
# Every worktree connects to the dev DB via the same host DATABASE_URL
# (localhost:5432), so they intentionally SHARE one Postgres container keyed by
# `container_name` ({{db_name}}). The first worktree to run `just db-up` creates
# it; later worktrees reuse it. The data lives in a project-prefixed named volume
# (see compose.yaml), so do NOT `docker compose down -v` / recreate the container
# from another worktree — that attaches a different empty volume and loses seeded
# data. `just db-down` stops (not removes) the container; the volume survives.

# ---------------------------------------------------------------------------
# App lifecycle
# ---------------------------------------------------------------------------

# build — compile the service. `just` binds recipe args POSITIONALLY (not
# `key=value`) — accept the documented `env=prod` spelling too by stripping a
# leading `env=` (matches `deploy`'s `dry_run=` handling below, and makes
# package.sh's own `PACKAGE_BUILD_CMD` default actually trigger a release build).
build env="dev":
    #!/usr/bin/env bash
    set -euo pipefail
    e="{{env}}"; e="${e#env=}"
    if [ "$e" = "prod" ]; then cargo build --release; else cargo build; fi

# run — start the service in dev mode (canonical name; `recipe.py server` and
# `recipe.py run` both resolve here). Depends on `db-up` (starts/reuses the
# compose datastore). Auto-seeds in dev only (fail-closed outside dev, #438)
# once `fixtures/` is adopted — see docs/design/fixtures-convention-design.md.
# `|| true` keeps `run` working exactly as before on a project that hasn't
# adopted it yet. Backgrounds the real process (nohup + disown for real
# detachment) and writes its PID so `just stop` (scripts/stop.sh) can find it.
run env="dev" port="3000": db-up
    #!/usr/bin/env bash
    set -euo pipefail
    e="{{env}}"; e="${e#env=}"
    if [ "$e" = "dev" ]; then
        python3 .claude/skills/grm-build-recipe/recipe.py seed --env dev --if-empty || true
    fi
    if [ "$e" = "prod" ]; then cargo build --release; bin="target/release/service-app"
    else cargo build; bin="target/debug/service-app"; fi
    pidfile="${GRIMOIRE_RUN_PIDFILE:-.grimoire-run.pid}"
    nohup "$bin" --port "{{port}}" >.grimoire-run.log 2>&1 &
    disown
    echo $! > "$pidfile"
    echo "service-app launched on port {{port}} (pid $(cat "$pidfile")); output at .grimoire-run.log."

# stop — kill running instance(s) of this project's process (#322, INTERFACE v6).
# Resolution order: port param -> $GRIMOIRE_APP_PORT -> the pidfile `run` writes
# -> a declared process pattern. Idempotent — nothing running is exit 0. See
# scripts/stop.sh for the generic reference implementation.
stop port="":
    scripts/stop.sh {{port}}

# test — run the test suite (unit + the process-spawning integration test in
# tests/service_integration.rs; cargo drives both).
test filter="" watch="":
    cargo test {{filter}}

# unit-test — fast, isolated subset only: in-module #[cfg(test)] unit tests
# via `cargo test --lib` (#360). Excludes the process-spawning integration
# test in tests/service_integration.rs — that stays in `just test`'s full run.
unit-test filter="" watch="":
    cargo test --lib {{filter}}

# seed — populate a local data store with fixtures (fixtures/ convention;
# see docs/design/fixtures-convention-design.md). Delegates to the framework's
# generic seed-dispatch engine — same delegation pattern as sync-deps/
# vendor-check below. Fail-closed outside dev: recipe.py refuses env != dev
# without an explicit --allow-non-dev override.
seed fixture="" env="dev":
    python3 .claude/skills/grm-build-recipe/recipe.py seed --fixture {{fixture}} --env {{env}}

# migrate — run pending schema / data migrations.
migrate env="dev":
    @echo "The healthz-only starter has no data store to migrate by default (env {{env}}) — wire recordkeeper/db-up first."

# lint — static analysis / formatting checks.
lint:
    cargo clippy --all-targets -- -D warnings

# clean — remove build artifacts.
clean:
    cargo clean
    rm -rf dist

# package — assemble a versioned, deployable release bundle in dist/.
# Delegates to the shared scripts/package.sh (resolves VERSION + TRIPLE, builds,
# stages dist/<name>-v{VER}-{TRIPLE}/, emits grimoire-build-info.json +
# release.json + SHA256SUMS, tars deterministically). Parameterized via
# scripts/package-manifest.sh. version/target default to "" so package.sh
# auto-detects from the manifest.
package version="" target="":
    #!/usr/bin/env bash
    set -euo pipefail
    args=()
    [ -n "{{version}}" ] && args+=(--version "{{version}}")
    [ -n "{{target}}" ] && args+=(--triple "{{target}}")
    scripts/package.sh ${args[@]+"${args[@]}"}

# deploy — push a packaged bundle to a named environment. env: REQUIRED (no
# default — forces explicit choice); dry_run: "true" to plan every action
# without executing side effects. Delegates to the shared scripts/deploy.sh.
deploy env dry_run="false":
    #!/usr/bin/env bash
    set -euo pipefail
    dr="{{dry_run}}"; dr="${dr#dry_run=}"
    if [ "$dr" = "true" ]; then scripts/deploy.sh {{env}} --dry-run; else scripts/deploy.sh {{env}}; fi

# smoke — boot-free liveness check: GET /healthz and assert a 2xx JSON body
# with {status, version} (web-app-deployment-protocol.md §5) — the SAME
# contract the web quick-start template's `just smoke` recipe asserts. port
# selects the local dev server port (defaults to 3000). Override the base URL
# via SMOKE_BASE_URL (else http://localhost:{{port}}, with $GRIMOIRE_APP_PORT
# honoured when port is left at its default).
smoke port="3000":
    #!/usr/bin/env bash
    set -euo pipefail
    base="${SMOKE_BASE_URL:-http://localhost:${GRIMOIRE_APP_PORT:-{{port}}}}"
    url="$base/healthz"
    echo "smoke: GET $url (port={{port}})"
    body="$(curl -fsS "$url")" || { echo "smoke: /healthz did not return 2xx" >&2; exit 1; }
    echo "$body" | python3 -c 'import json,sys; d=json.load(sys.stdin); assert "status" in d and "version" in d, "healthz JSON must carry {status, version}: %r" % d; print("smoke: OK status=%s version=%s" % (d["status"], d["version"]))'

# gui-test — platform-differentiated GUI feature test (#362); a backend
# service has no GUI surface to test.
gui-test baseline="main":
    @echo "A backend service has no GUI surface to gui-test (baseline {{baseline}})."

# release — the changelog-derived release ceremony (no args). Delegates to the
# shared scripts/release.sh (derives VERSION from docs/version-history.md,
# guards, bumps Cargo.toml, tests + builds, archives via `just package`,
# commits + tags, then publishes once the tag reaches the remote — see the
# script header for the full ceremony).
release *ARGS:
    scripts/release.sh {{ARGS}}

# sync-deps — reconcile / vendor first-party deps from a release channel.
# Delegates to the framework consume-side script; mode selects --check/--update/--offline.
sync-deps mode="":
    python3 .claude/skills/grm-sync-deps/sync_deps.py {{mode}}

# vendor-check — dependency-channel conformance gate (exit 0/nonzero). Delegates
# to the framework script; full selects the whole-vendor audit.
vendor-check full="":
    python3 .claude/skills/grm-dependency-audit/dependency_channel_conformance.py --root . {{full}}

# trim — safe worktree reap (dry-run by default) + this worktree's own cargo-
# artifact sweep (#446). Human/master-invoked convenience, not an automated
# call site — unlike worktree_reap.py's own destructive-by-default CLI
# posture (every other #449 call site already wraps it in its own
# confirmation layer, disk-branch-hygiene-design.md §Scope), `trim` inverts
# that: dry-run (preview only) unless `--confirm` is passed. `--dry-run` is
# accepted explicitly too (the acceptance-tested spelling) and always wins
# over `--confirm` if both are given. `--landed-ref REF` overrides what
# "landed" means for the #444 predicate (default `dev`; pass
# `--landed-ref version/3.95` during an in-flight release). Auto-discovers
# dead agent-branch worktrees (`claude/…`, #456 namespace) — never touches a
# human branch/worktree.
#
# CAVEAT — the cargo sweep is scoped to THIS worktree only: a worktree that
# gets reaped above already loses its whole target/ for free via
# `git worktree remove`, so there is nothing extra to sweep there. Sweeping
# THIS worktree's own target/ cannot generically know whether a build here
# is still needed, so it stays behind the same explicit `--confirm` gate
# (never runs on a bare `just trim` or `--dry-run`) and is documented here as
# a known, deliberate limitation rather than solved automatically.
trim *ARGS:
    #!/usr/bin/env bash
    set -euo pipefail
    python3 .claude/skills/grm-worktree-preflight/trim.py {{ARGS}}
    a=" {{ARGS}} "
    if [[ "$a" == *" --confirm "* && "$a" != *" --dry-run "* ]]; then
        echo "trim: sweeping this worktree's own cargo build artifacts (cargo clean)…"
        cargo clean
    else
        echo "trim: DRY-RUN — would also run 'cargo clean' in this worktree (pass --confirm to sweep it; forces a full rebuild on the next 'just build')."
    fi
