# Quick-start task runner (just — https://github.com/casey/just) — GUI/desktop app.
#
# Ships the full build-recipe vocabulary (RSS-3, #321): every INTERFACE target
# has a standard `just` recipe here — the one place recipes live. `recipe.py
# <t>` routes to `just <t>` via .claude/recipes.json.
#
# REAL, running recipes: `build`/`run`/`stop`/`test`/`package`/`release`/
# `smoke`/`gui-test` call cargo / the shared scripts/{package,release,stop}.sh
# directly — no `# grimoire:placeholder` bodies. `run` opens the ACTUAL native
# egui/eframe window; `smoke`/`--smoke-test` boot the SAME app state
# headlessly (no display required) for CI; `gui-test`/`--gui-test` extend
# that same headless boot with a deterministic render snapshot diffed
# against a committed baseline (#362). Authority:
# docs/design/justfile-standard-design.md +
# docs/grimoire/design/build-recipe-interface-design.md.

set shell := ["bash", "-uc"]

# build — compile the desktop app into target/. `just` binds recipe args
# POSITIONALLY (not `key=value`) — accept the documented `env=prod` spelling
# too by stripping a leading `env=` (matches `deploy`'s `dry_run=` handling
# below, and makes package.sh's own `PACKAGE_BUILD_CMD` default actually
# trigger a release build).
build env="dev":
    #!/usr/bin/env bash
    set -euo pipefail
    e="{{env}}"; e="${e#env=}"
    if [ "$e" = "prod" ]; then cargo build --release; else cargo build; fi

# run — launch the desktop application (opens a REAL native window).
# `nohup ... & disown` fully detaches the process (survives the recipe shell
# exiting — plain `&` alone can still get SIGHUP'd along with its process
# group in some shells/harnesses) and writes its PID so `just stop` can find
# it, matching the web quick-start template's `run` doc comment.
run env="dev" port="3000":
    #!/usr/bin/env bash
    set -euo pipefail
    e="{{env}}"; e="${e#env=}"
    if [ "$e" = "prod" ]; then cargo build --release; bin="target/release/gui-app"
    else cargo build; bin="target/debug/gui-app"; fi
    pidfile="${GRIMOIRE_RUN_PIDFILE:-.grimoire-run.pid}"
    nohup "$bin" >.grimoire-run.log 2>&1 &
    disown
    echo $! > "$pidfile"
    echo "gui-app launched (pid $(cat "$pidfile")); output at .grimoire-run.log."

# stop — kill the running gui-app instance (#322, INTERFACE v6). See
# scripts/stop.sh for the generic reference implementation (pidfile /
# port / declared-pattern resolution, idempotent).
stop port="":
    scripts/stop.sh {{port}}

# test — run the test suite (unit + the process-spawning smoke integration
# test in tests/gui_smoke_integration.rs; cargo drives both).
test filter="" watch="":
    cargo test {{filter}}

# unit-test — fast, isolated subset only: in-module #[cfg(test)] unit tests
# via `cargo test --lib` (#360). Excludes the process-spawning smoke
# integration test in tests/gui_smoke_integration.rs — that stays in
# `just test`'s full run.
unit-test filter="" watch="":
    cargo test --lib {{filter}}

# seed — populate a local data store with fixtures (fixtures/ convention;
# see docs/design/fixtures-convention-design.md). Delegates to the framework's
# generic seed-dispatch engine — same delegation pattern as sync-deps/
# vendor-check below. Fail-closed outside dev: recipe.py refuses env != dev
# without an explicit --allow-non-dev override.
seed fixture="" env="dev":
    python3 .claude/skills/grm-build-recipe/recipe.py seed --fixture {{fixture}} --env {{env}}

# migrate — run pending schema / data migrations.
migrate env="dev":
    @echo "A desktop app scaffold has no data store to migrate by default (env {{env}})."

# lint — static analysis / formatting checks.
lint:
    cargo clippy --all-targets -- -D warnings

# clean — remove build artifacts.
clean:
    cargo clean
    rm -rf dist

# package — assemble a versioned, distributable bundle in dist/. Delegates to
# the shared scripts/package.sh (resolves VERSION + TRIPLE, builds, stages
# dist/<name>-v{VER}-{TRIPLE}/, emits grimoire-build-info.json + release.json +
# SHA256SUMS, tars deterministically). Parameterized via
# scripts/package-manifest.sh. version/target default to "" so package.sh
# auto-detects from the manifest.
package version="" target="":
    #!/usr/bin/env bash
    set -euo pipefail
    args=()
    [ -n "{{version}}" ] && args+=(--version "{{version}}")
    [ -n "{{target}}" ] && args+=(--triple "{{target}}")
    scripts/package.sh ${args[@]+"${args[@]}"}

# deploy — publish the packaged distributable to a release channel. env:
# REQUIRED (no default — forces an explicit choice). Delegates to the shared
# scripts/deploy.sh, which reads the `environments` block and branches on
# transport (ssh | local-symlink | pull) × service_manager.
deploy env dry_run="false":
    #!/usr/bin/env bash
    set -euo pipefail
    dr="{{dry_run}}"; dr="${dr#dry_run=}"
    if [ "$dr" = "true" ]; then scripts/deploy.sh {{env}} --dry-run; else scripts/deploy.sh {{env}}; fi

# smoke — display-free liveness check: boot real app state + render one
# headless egui frame (no native window, no display required).
smoke port="3000":
    #!/usr/bin/env bash
    set -euo pipefail
    bin="target/release/gui-app"; [ -x "$bin" ] || bin="target/debug/gui-app"
    if [ ! -x "$bin" ]; then
        echo "smoke: no binary at target/{release,debug}/gui-app — run 'just build' first." >&2
        exit 1
    fi
    "$bin" --smoke-test

# gui-test — desktop GUI feature test (#362, platform-differentiated GUI
# testing): headless boot + render, then diff a deterministic text snapshot
# of what the UI drew against the committed baseline
# tests/gui-baselines/<baseline>.snapshot. A missing baseline is always a
# hard failure — same convention as smoke-visual. Update deliberately with
# `just gui-test main update_baseline=true` after reviewing the drift. See
# docs/grimoire/design/runtime-verification-design.md §GUI testing for why
# this is a text snapshot rather than a rasterized PNG.
gui-test baseline="main" update_baseline="false":
    #!/usr/bin/env bash
    set -euo pipefail
    bin="target/release/gui-app"; [ -x "$bin" ] || bin="target/debug/gui-app"
    if [ ! -x "$bin" ]; then
        echo "gui-test: no binary at target/{release,debug}/gui-app — run 'just build' first." >&2
        exit 1
    fi
    ub="{{update_baseline}}"; ub="${ub#update_baseline=}"
    if [ "$ub" = "true" ]; then
        "$bin" --gui-test {{baseline}} --update-baseline
    else
        "$bin" --gui-test {{baseline}}
    fi

# release — the changelog-derived release ceremony (no args). Delegates to the
# shared scripts/release.sh (derives VERSION from docs/version-history.md,
# guards, bumps Cargo.toml, tests + builds, archives via `just package`,
# commits + tags, then publishes once the tag reaches the remote — see the
# script header for the full ceremony).
release *ARGS:
    scripts/release.sh {{ARGS}}

# sync-deps — reconcile / vendor first-party deps from a release channel.
# Delegates to the framework consume-side script; mode selects --check/--update/--offline.
sync-deps mode="":
    python3 .claude/skills/grm-sync-deps/sync_deps.py {{mode}}

# vendor-check — dependency-channel conformance gate (exit 0/nonzero). Delegates
# to the framework script; full selects the whole-vendor audit.
vendor-check full="":
    python3 .claude/skills/grm-dependency-audit/dependency_channel_conformance.py --root . {{full}}

# trim — safe worktree reap (dry-run by default) + this worktree's own cargo-
# artifact sweep (#446). Human/master-invoked convenience, not an automated
# call site — unlike worktree_reap.py's own destructive-by-default CLI
# posture (every other #449 call site already wraps it in its own
# confirmation layer, disk-branch-hygiene-design.md §Scope), `trim` inverts
# that: dry-run (preview only) unless `--confirm` is passed. `--dry-run` is
# accepted explicitly too (the acceptance-tested spelling) and always wins
# over `--confirm` if both are given. `--landed-ref REF` overrides what
# "landed" means for the #444 predicate (default `dev`; pass
# `--landed-ref version/3.95` during an in-flight release). Auto-discovers
# dead agent-branch worktrees (`claude/…`, #456 namespace) — never touches a
# human branch/worktree.
#
# CAVEAT — the cargo sweep is scoped to THIS worktree only: a worktree that
# gets reaped above already loses its whole target/ for free via
# `git worktree remove`, so there is nothing extra to sweep there. Sweeping
# THIS worktree's own target/ cannot generically know whether a build here
# is still needed, so it stays behind the same explicit `--confirm` gate
# (never runs on a bare `just trim` or `--dry-run`) and is documented here as
# a known, deliberate limitation rather than solved automatically.
trim *ARGS:
    #!/usr/bin/env bash
    set -euo pipefail
    python3 .claude/skills/grm-worktree-preflight/trim.py {{ARGS}}
    a=" {{ARGS}} "
    if [[ "$a" == *" --confirm "* && "$a" != *" --dry-run "* ]]; then
        echo "trim: sweeping this worktree's own cargo build artifacts (cargo clean)…"
        cargo clean
    else
        echo "trim: DRY-RUN — would also run 'cargo clean' in this worktree (pass --confirm to sweep it; forces a full rebuild on the next 'just build')."
    fi
