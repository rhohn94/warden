    @echo "TODO: replace with the clean command (e.g. rm -rf dist/ target/)."

# package — build the publishable distribution (wheel / crate / npm tarball).
package version="" target="":
    # grimoire:placeholder
    @echo "TODO: replace with the package command (version {{version}}, target {{target}})."

# deploy — a library publishes rather than deploys; implement `release` instead.
deploy env dry_run="false":
    # grimoire:placeholder
    @echo "A library has no deploy target — use `release` to publish (env {{env}})."

# smoke — runtime verification; a pure library usually has none.
smoke port="3000":
    # grimoire:placeholder
    @echo "A pure library has no served surface to smoke-check (port {{port}})."

# release — the changelog-derived release/publish ceremony. See the web
# quick-start template for a scripts/release.sh reference implementation.
release *ARGS:
