    @echo "TODO: replace with the release/publish ceremony (see the web template's scripts/release.sh)."

# sync-deps — reconcile / vendor first-party deps from a release channel.
# Delegates to the framework consume-side script; mode selects --check/--update/--offline.
sync-deps mode="":
    python3 .claude/skills/grm-sync-deps/sync_deps.py {{mode}}

# vendor-check — dependency-channel conformance gate (exit 0/nonzero). Delegates
# to the framework script; full selects the whole-vendor audit.
vendor-check full="":
    python3 .claude/skills/grm-dependency-audit/dependency_channel_conformance.py --root . {{full}}
