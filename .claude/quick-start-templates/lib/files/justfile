    @echo "TODO: replace with the build command (env {{env}})."

# run — a library has no runnable entrypoint; present for vocabulary uniformity.
run env="dev" port="3000":
    # grimoire:placeholder
    @echo "A library has no run target — implement only if the project ships a demo/CLI."

# stop — a library has no runnable entrypoint; present for vocabulary uniformity.
stop port="":
    # grimoire:placeholder
    @echo "A library has no run target to stop — implement only if the project ships a demo/CLI."

# test — run the test suite.
test filter="" watch="":
    # grimoire:placeholder
    @echo "TODO: replace with the test command (e.g. pytest {{filter}}, cargo test)."

# seed — populate a local data store with fixtures.
seed fixture="" env="dev":
    # grimoire:placeholder
    @echo "TODO: replace with the seed command (fixture {{fixture}}, env {{env}})."

# migrate — run pending schema / data migrations.
migrate env="dev":
    # grimoire:placeholder
    @echo "TODO: replace with the migrate command (env {{env}})."

# lint — static analysis / formatting checks.
lint:
