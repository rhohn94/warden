# run — start the web app in dev mode (canonical name; `recipe.py server` and
# `recipe.py run` both resolve here). Run `just build` first if your project
# requires compiled artifacts before the process can start. When you wire the
# real run command, background it and write its PID to $GRIMOIRE_RUN_PIDFILE
# (default .grimoire-run.pid) so `just stop` (scripts/stop.sh) can find and kill
# it, e.g.: `nohup <entrypoint> & echo $! > "${GRIMOIRE_RUN_PIDFILE:-.grimoire-run.pid}"`.
# Auto-seeds in dev only (fail-closed outside dev, #438) once `fixtures/` is
# adopted — see docs/design/fixtures-convention-design.md. `|| true` keeps
# `run` working exactly as before on a project that hasn't adopted it yet.
run env="dev" port="3000": db-up
    #!/usr/bin/env bash
    set -euo pipefail
    if [ "{{env}}" = "dev" ]; then
        python3 .claude/skills/grm-build-recipe/recipe.py seed --env dev --if-empty || true
    fi
    # grimoire:placeholder
    echo "TODO: replace with the run command (e.g. the web app entrypoint) on port {{port}}, env {{env}}."

# stop — kill running instance(s) of this project's process (#322, INTERFACE v6).
# Resolution order: port param -> $GRIMOIRE_APP_PORT -> the pidfile `run` writes
# -> a declared process pattern. Idempotent — nothing running is exit 0. See
# scripts/stop.sh for the generic reference implementation.
stop port="":
    scripts/stop.sh {{port}}

