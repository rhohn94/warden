# api-types-check — drift gate: regenerate into a temp dir and diff against
# the committed types; nonzero exit on drift. Wired into `test`'s
# prerequisite chain above.
api-types-check:
    scripts/api_types.sh check

# sync-deps — reconcile / vendor first-party deps from a release channel.
# Delegates to the framework consume-side script; mode selects --check/--update/--offline.
sync-deps mode="":
    python3 .claude/skills/grm-sync-deps/sync_deps.py {{mode}}

# vendor-check — dependency-channel conformance gate (exit 0/nonzero). Delegates
# to the framework script; full selects the whole-vendor audit.
vendor-check full="":
    python3 .claude/skills/grm-dependency-audit/dependency_channel_conformance.py --root . {{full}}

# package — assemble a versioned, deployable release bundle in dist/.
# Delegates to the shared scripts/package.sh (resolves VERSION + TRIPLE, builds,
# stages dist/<name>-v{VER}-{TRIPLE}/, emits release.json + SHA256SUMS, and tars
# deterministically). Parameterize the app via scripts/package-manifest.sh (see
# the PACKAGE_* contract in scripts/package.sh) or pass version/target explicitly.
# version/target default to "" so package.sh auto-detects from the manifest / env.
package version="" target="":
    #!/usr/bin/env bash
    set -euo pipefail
    args=()
    [ -n "{{version}}" ] && args+=(--version "{{version}}")
    [ -n "{{target}}" ] && args+=(--triple "{{target}}")
    scripts/package.sh ${args[@]+"${args[@]}"}

# deploy — push a packaged bundle to a named environment.
# env: REQUIRED (no default — forces explicit choice); one of the environments
#      declared in .claude/grimoire-config.json (local | dev | beta | production).
# dry_run: "true" to plan every action without executing side effects.
# Delegates to the shared scripts/deploy.sh, which reads the `environments` block
# and branches on transport (ssh | local-symlink | pull) × service_manager.
deploy env dry_run="false":
    #!/usr/bin/env bash
    set -euo pipefail
    # `just` binds recipe args positionally: prefer `just deploy prod true`. Accept
    # the documented `dry_run=true` spelling too by stripping a leading `dry_run=`
    # (just would otherwise pass the whole token as the positional value).
    dr="{{dry_run}}"; dr="${dr#dry_run=}"
    if [ "$dr" = "true" ]; then
        scripts/deploy.sh {{env}} --dry-run
    else
        scripts/deploy.sh {{env}}
    fi

# smoke — boot-free liveness check: GET /healthz and assert a 2xx JSON body with
# {status, version} (web-app-deployment-protocol.md §5). port selects the local
# dev server port (matches the build-recipe `smoke` param; defaults to 3000).
# Override the base URL via SMOKE_BASE_URL (else http://localhost:{{port}}, with
# $GRIMOIRE_APP_PORT honoured when port is left at its default).
smoke port="3000":
    #!/usr/bin/env bash
    set -euo pipefail
    base="${SMOKE_BASE_URL:-http://localhost:${GRIMOIRE_APP_PORT:-{{port}}}}"
    url="$base/healthz"
    echo "smoke: GET $url (port={{port}})"
    body="$(curl -fsS "$url")" || { echo "smoke: /healthz did not return 2xx" >&2; exit 1; }
    echo "$body" | python3 -c 'import json,sys; d=json.load(sys.stdin); assert "status" in d and "version" in d, "healthz JSON must carry {status, version}: %r" % d; print("smoke: OK status=%s version=%s" % (d["status"], d["version"]))'

# gui-test — platform-differentiated GUI feature test (#362). For a web
# project this is NOT a scriptable target: a shell recipe cannot drive an
# MCP browser tool. The actual verification is the agent session itself
# exercising the changed flow via the Preview surface (preview_start /
# navigate / read_page / computer interaction + read_console_messages),
# per docs/grimoire/design/runtime-verification-design.md §GUI testing —
# that Preview-driven pass IS the "gui-test" for a web feature; this recipe
# stays an advisory stub (exit 2) so `recipe.py gui-test` never silently
# no-ops or falsely reports pass/fail for something it cannot run. baseline
# is accepted for interface-shape parity with the desktop leg but unused
# here.
gui-test baseline="main":
    # grimoire:placeholder
    @echo "gui-test: web GUI testing is agent-driven via the Preview surface, not a scriptable recipe — see docs/grimoire/design/runtime-verification-design.md §GUI testing. This stub intentionally stays unimplemented (recipe.py reports exit 2 advisory) rather than faking a pass/fail it cannot observe."

# release — the changelog-derived release ceremony (no args).
# Delegates to the shared scripts/release.sh, which derives the version from the
# newest heading in the changelog (docs/version-history.md by default), runs the
# guards (release branch, clean tree, tag absent, changelog entry present), bumps
# the project's version file(s), runs test + release build, archives, commits the
# bump, tags, and reconciles the matching milestone:v{X.Y} issues into release
# notes (via the grm-issue-tracker abstraction — github + roadmap both work).
# Parameterize via scripts/release-manifest.sh (see the RELEASE_* contract in
# scripts/release.sh). Pass extra flags through (e.g. `just release --dry-run`).
release *ARGS:
    scripts/release.sh {{ARGS}}

# smoke-visual — scripted-screenshot pixel-diff smoke gate (Grimoire #289, RSS-9).
# Generalizes the fleet's pixel-diff harness (forge-engine/obsidian/retro-game-
# player) into one reusable recipe: captures each configured route via a
# project-declared headless-browser command, diffs against the committed
# baseline in tests/smoke-baselines/, and hard-fails on a MISSING baseline
# (never a silent no-op — closes the forge-engine#150 class of bug). This
# extends the curl-based `smoke` floor above with a slower, browser-based
# visual-regression layer; it is NOT part of the versioned build-recipe
# INTERFACE vocabulary (see .claude/recipes.json `extras.smoke-visual`).
# Configure via scripts/smoke-visual-manifest.sh (SMOKE_VISUAL_* contract — see
# the header of scripts/smoke-visual.sh) or CLI flags (--route, --capture-cmd).
# port: local dev server port (matches `run`/`smoke`; defaults to 3000).
# update_baselines: "true" to regenerate the committed references from the
# current capture — the documented workflow after an intentional UI change
# (docs/grimoire/design/runtime-verification-design.md §Visual smoke gate).
smoke-visual port="3000" update_baselines="false":
    #!/usr/bin/env bash
    set -euo pipefail
    # `just` binds recipe args positionally: prefer `just smoke-visual 3000 true`.
    # Accept the documented `port=3000`/`update_baselines=true` spelling too (the
    # same convenience `deploy`'s dry_run accepts above) by stripping a leading
    # `port=`/`update_baselines=` — `just` would otherwise pass the whole token
    # as the positional value.
    p="{{port}}"; p="${p#port=}"
    ub="{{update_baselines}}"; ub="${ub#update_baselines=}"
    args=(--port "$p")
    [ "$ub" = "true" ] && args+=(--update-baselines)
    scripts/smoke-visual.sh "${args[@]}"

# trim — safe worktree reap (dry-run by default; #446). Human/master-invoked
# convenience, not an automated call site — unlike worktree_reap.py's own
# destructive-by-default CLI posture (every other #449 call site already
# wraps it in its own confirmation layer, disk-branch-hygiene-design.md
# §Scope), `trim` inverts that: dry-run (preview only) unless `--confirm` is
# passed. `--dry-run` is accepted explicitly too (the acceptance-tested
# spelling) and always wins over `--confirm` if both are given.
# `--landed-ref REF` overrides what "landed" means for the #444 predicate
# (default `dev`; pass `--landed-ref version/3.95` during an in-flight
# release). Auto-discovers dead agent-branch worktrees (`claude/…`, #456
# namespace) — never touches a human branch/worktree. No cargo-artifact
# sweep here — this scaffold isn't Cargo-based (see the cli/gui/lib/service
# quick-start templates' `trim` for the Cargo-sweep half).
trim *ARGS:
    python3 .claude/skills/grm-worktree-preflight/trim.py {{ARGS}}
